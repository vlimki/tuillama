# Example tuillama configuration.
# Every value below is shown with the current default or an example default-like value.
# You can uncomment and tweak anything you want.

model = "gpt-oss:20b"
api_url = "http://127.0.0.1:11434/api/chat"
server_addr = "127.0.0.1:7878"
system_prompt = "You are a helpful assistant."

# Needed for web search functionality
ollama_api_key = ""

# In visual mode, render the selected message in bold instead of reversing the background.
bold_selection = true

# Legacy syntax theme key; prefer [syntax].theme_name for new configs.
# syntax_theme = "base16-ocean.dark"

[preview]
preview_fmt = "pdf"
preview_open = "zathura"

[performance]
stream_fps = 30
input_poll_ms = 250

[options]
# Common Ollama options forwarded directly to the provider.
# num_ctx = 4096
# num_thread = 6
# temperature = 0.7
# num_gpu = 50

# Names or #RRGGBB values.
[colors]
app_bg = "black"
panel_bg = "black"
panel_alt_bg = "black"
input_bg = "black"

sidebar_title = "blue"
sidebar_timestamp = "dark_gray"
sidebar_item = "white"
sidebar_item_bg = "black"
sidebar_selected_bg = "blue"

title_chat = "blue"
title_input = "white"
title_bar_bg = "black"

user_prefix = "magenta"
assistant_prefix = "magenta"
system_prefix = "red"
message_meta = "dark_gray"
message_rule = "#444953"

heading1 = "cyan"
heading2 = "light_yellow"
heading3 = "cyan"
heading4 = "light_cyan"
blockquote_bar = "dark_gray"
list_bullet = "green"
ordered_number = "green"
inline_code = "yellow"
inline_code_bg = "#050505"
code_block_fg = "gray"
code_block_bg = "#050505"
hr = "dark_gray"

status_hint = "gray"
mode_insert = "green"
mode_normal = "yellow"
mode_visual = "light_magenta"
mode_focus = "blue"

border_sidebar = "dark_gray"
border_chat = "dark_gray"
border_input = "dark_gray"

popup_title = "light_red"
popup_accent = "yellow"
popup_text = "white"

stats_label = "dark_gray"
stats_value = "white"
stats_accent = "green"

[syntax]
enabled = true
theme_name = "base16-ocean.dark"

# Custom syntax palette (takes precedence over theme_name when present)
[syntax.custom]
keyword = "blue"
string = "green"
comment = "dark_gray"
type = "yellow"
function = "magenta"
number = "magenta"
operator = "white"
punct = "light_gray"
text = "white"
