# Example tuillama configuration.
# Every value below is shown with the current default or an example default-like value.
# You can uncomment and tweak anything you want.

model = "llama3"
api_url = "http://localhost:11434/api/chat"
# Optional for hosted Ollama-compatible providers
ollama_api_key = ""
server_addr = "127.0.0.1:7878"
system_prompt = "You are a helpful assistant."

# In visual mode, render the selected message in bold instead of reversing the background.
bold_selection = false

# Legacy syntax theme key; prefer [syntax].theme_name for new configs.
# syntax_theme = "base16-ocean.dark"

[preview]
preview_fmt = "html"
preview_open = "xdg-open"

[performance]
stream_fps = 30
input_poll_ms = 250

[options]
# Common Ollama options forwarded directly to the provider.
# num_ctx = 4096
# num_thread = 6
# temperature = 0.7
# num_gpu = 50

# Names or #RRGGBB values.
[colors]
app_bg = "#0d0f14"
panel_bg = "#16181e"
panel_alt_bg = "#1c1f26"

sidebar_title = "#7ed3ff"
sidebar_timestamp = "#7d818a"
sidebar_item = "#e8eaee"
sidebar_selected_bg = "#2f3640"

title_chat = "#7ed3ff"
title_input = "#e3e4e8"
title_bar_bg = "#1f2229"

user_prefix = "#7ed3ff"
assistant_prefix = "#f1d77a"
system_prefix = "#ffc36e"
message_meta = "#8c909a"
message_rule = "#444953"

heading1 = "#f1d77a"
heading2 = "light_yellow"
heading3 = "cyan"
heading4 = "light_cyan"
blockquote_bar = "dark_gray"
list_bullet = "green"
ordered_number = "green"
inline_code = "yellow"
inline_code_bg = "dark_gray"
code_block_fg = "gray"
code_block_bg = "black"
hr = "dark_gray"

status_hint = "gray"
mode_insert = "green"
mode_normal = "yellow"
mode_visual = "light_magenta"
mode_focus = "blue"

border_sidebar = "gray"
border_chat = "gray"
border_input = "gray"

popup_title = "light_red"
popup_accent = "#f1d77a"
popup_text = "#dcdfe4"

stats_label = "#aaaeb6"
stats_value = "#e6e8ec"
stats_accent = "#6fdb7b"

[syntax]
enabled = true
theme_name = "base16-ocean.dark"

# Custom syntax palette (takes precedence over theme_name when present)
[syntax.custom]
keyword = "#CC99CD"
string = "#7EC699"
comment = "#999999"
type = "#5FB4B4"
function = "#6699CC"
number = "#F2777A"
operator = "#F99157"
punct = "light_gray"
text = "white"
